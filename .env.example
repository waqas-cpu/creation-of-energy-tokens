# Repo root — local only (copy to .env). Never commit .env.

SUI_NETWORK=testnet    

# RPC (pick one)
# QuickNode: paste full HTTPS endpoint (token is in the URL path) — leave SUI_RPC_API_KEY empty
# SUI_RPC_URL=https://YOUR-NAME.sui-testnet.quiknode.pro/YOUR_TOKEN
# Shinami: fixed URL + separate key (us1_sui_testnet_...)
# SUI_RPC_URL=https://api.us1.shinami.com/sui/node/v1
# SUI_RPC_API_KEY=
# BLOCKVISION_RPC_URL=https://sui-testnet.blockvision.org/v1/YOUR_KEY
SUI_RPC_URL=
SUI_RPC_API_KEY=

# After publish (layer3/move + layer5/move) — required for on-chain submit
L5_PACKAGE_ID=
L3_GRID_PACKAGE_ID=
L5_TREASURY_GUARD_ID=
L5_ENERGY_BATCH_ID=
L5_ENERGY_COIN_ID=
L5_ENERGY_METER_ID=
L5_COMPLIANCE_REGISTRY_ID=
L5_JURISDICTION_POLICY_ID=
L5_REDEMPTION_REGISTRY_ID=
L5_GRID_OPERATOR_CAP_ID=
L5_BILLING_OPERATOR_CAP_ID=
L5_GRID_SETTLEMENT_LEDGER_ID=

# Signer for POST /v1/redemption/submit
SUI_SIGNER_SECRET_KEY=

# Backend persistence + security
SETTLEMENT_DATA_DIR=./settlement-data  
SETTLEMENT_API_PORT=3750
SETTLEMENT_API_KEY=
SETTLEMENT_API_PUBLIC_READ=false

# IPFS real CIDs (docker: IPFS_KUBO_API_URL=http://127.0.0.1:5001)
IPFS_PROVIDER=kubo
IPFS_KUBO_API_URL=http://127.0.0.1:5001
# IPFS_PROVIDER=pinata
# PINATA_JWT=

# Workers
EVENT_INDEXER_POLL_MS=10000
BRIDGE_WATCHER_POLL_MS=30000

# Checks: npm run gate:checklist:rpc
