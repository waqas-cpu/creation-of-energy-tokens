# After publishing Layer 3 (energy_grid) and Layer 5 (energy_settlement) on testnet:
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Shinami (or other hosted RPC): URL + API key sent as X-Api-Key — never commit real keys
# SUI_RPC_URL=https://api.us1.shinami.com/sui/node/v1
# SUI_RPC_API_KEY=
# Aliases: SHINAMI_NODE_URL, SHINAMI_SUI_NODE_URL, SHINAMI_API_KEY, SHINAMI_ACCESS_KEY
# Gate 6 — durable audit / proofs / reports + optional HTTP API
# SETTLEMENT_DATA_DIR=./settlement-data
# SETTLEMENT_API_PORT=3750

L3_GRID_PACKAGE_ID=0x...
L5_PACKAGE_ID=0x...

L5_TREASURY_GUARD_ID=0x...
L5_ENERGY_BATCH_ID=0x...
L5_ENERGY_COIN_ID=0x...
L5_ENERGY_METER_ID=0x...
L5_COMPLIANCE_REGISTRY_ID=0x...
L5_JURISDICTION_POLICY_ID=0x...
L5_REDEMPTION_REGISTRY_ID=0x...
L5_GRID_OPERATOR_CAP_ID=0x...
L5_BILLING_OPERATOR_CAP_ID=0x...
L5_GRID_SETTLEMENT_LEDGER_ID=0x...

# Optional — required only for signAndExecute (not dry-run inspect)
SUI_SIGNER_SECRET_KEY=
