# Mainnet production — fill after publish + initialize_l5_infrastructure
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
# Shinami / custom RPC: SUI_RPC_API_KEY (X-Api-Key); aliases SHINAMI_* — do not commit secrets
# SETTLEMENT_DATA_DIR=./settlement-data
# SETTLEMENT_API_PORT=3750

# Layer 3 energy_grid (publish layer3/move first)
L3_GRID_PACKAGE_ID=0x...
L3_TREASURY_GUARD_ID=0x...
L3_COMPLIANCE_REGISTRY_ID=0x...
L3_ENERGY_METER_ID=0x...

# Layer 5 energy_settlement
L5_PACKAGE_ID=0x...
L5_TREASURY_GUARD_ID=0x...
L5_ENERGY_BATCH_ID=0x...
L5_ENERGY_COIN_ID=0x...
L5_ENERGY_METER_ID=0x...
L5_COMPLIANCE_REGISTRY_ID=0x...
L5_JURISDICTION_POLICY_ID=0x...
L5_REDEMPTION_REGISTRY_ID=0x...
L5_GRID_OPERATOR_CAP_ID=0x...
L5_BILLING_OPERATOR_CAP_ID=0x...
L5_GRID_SETTLEMENT_LEDGER_ID=0x...

# Governance (recommended)
SUI_TREASURY_MULTISIG=0x...
SUI_UPGRADE_AUTHORITY=0x...

# Signing — use multisig on mainnet
SUI_MULTISIG_PUBLIC_KEY=
SUI_SIGNER_SECRET_KEY=

# External APIs
CIRCLE_API_KEY=
GRID_OPERATOR_API=https://your-grid-operator.example/v1
GRID_OPERATOR_API_KEY=
PYTH_PRICE_FEED_ID=0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d

# Shared infra from config/networks/mainnet.json (verify with npm run production:check:rpc)
# WORMHOLE_STATE / PYTH_STATE used by PTB builders via manifest — no duplicate env required

# Wormhole emitter (after carbon bridge config + create_emitter_cap)
WORMHOLE_EMITTER_CAP_ID=0x...
WORMHOLE_STATE_OBJECT=0xaeab97f96cf9877fee2883315d459552b2b921edc16d7ceac6eab944dd88919c

# Native USDC settlement objects (after deploy_init)
L5_USDC_MARKETPLACE_ID=0x...
L5_PRICE_FEED_ID=0x...
L5_USDC_COMPLIANCE_REGISTRY_ID=0x...

# Pre-flight: npm run production:check:rpc (from layer5/settlement)
